{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicetauri/main/crates/tauri-config-schema/schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-set-title"
  ]
}
